# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/skillchef?retryWrites=true&w=majority

# Authentication Secrets
JWT_SECRET=skill_chef_super_secret_key_change_me_in_production

# OpenAI API Key (Optional: Simulated response fallback used if omitted)
OPENAI_API_KEY=your_openai_api_key_here

# Cloudinary Credentials (Optional: Food media placeholders used if omitted)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
